{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://gcmp.dev/schemas/provider-config.schema.json",
    "title": "GCMP Provider Configuration",
    "type": "object",
    "required": ["displayName", "baseUrl", "apiKeyTemplate", "models"],
    "additionalProperties": false,
    "properties": {
        "displayName": {
            "type": "string",
            "minLength": 1,
            "description": "在提供商选择器中显示的用户友好名称。"
        },
        "baseUrl": {
            "type": "string",
            "format": "uri",
            "description": "OpenAI 兼容请求的基础 URL。"
        },
        "apiKeyTemplate": {
            "type": "string",
            "minLength": 16,
            "description": "指导用户预期 API 密钥格式的占位符模式。"
        },
        "codingKeyTemplate": {
            "type": "string",
            "minLength": 16,
            "description": "指导用户预期 Coding Plan API 密钥格式的占位符模式。"
        },
        "tokenKeyTemplate": {
            "type": "string",
            "minLength": 16,
            "description": "指导用户预期 Token Plan API 密钥格式的占位符模式。"
        },
        "customHeader": {
            "type": "object",
            "description": "可选的自定义HTTP头部，将在该提供商的所有API请求中附加。模型级别的 customHeader 会覆盖提供商级别的设置。",
            "additionalProperties": {
                "type": "string",
                "description": "HTTP头部值",
                "minLength": 1
            }
        },
        "models": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/model"
            },
            "description": "提供商公开的模型列表。"
        },
        "retry": {
            "type": "object",
            "description": "内置预置重试配置（可选）。作为「全局 gcmp.retry.*」与「用户 providerOverrides.retry」之间的中间层：优先级为 providerOverrides.retry → 此处预置 → 全局默认。适用于内置 provider 已知需要特殊重试策略的场景（如某些提供商限流退避建议更长、或对 5xx 不敏感需禁用重试）。-1 无限重试、0 禁止重试、正整数不限上限。可通过 flat key（如 \"retry.xfyun-coding\"）为指定子 provider 配置独立的重试策略。",
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "是否对该提供商启用重试。缺省时回退到全局 gcmp.retry.enabled。"
                },
                "maxAttempts": {
                    "anyOf": [{ "const": -1 }, { "const": 0 }, { "type": "integer", "minimum": 1 }],
                    "description": "最大重试次数。-1 = 无限重试（仅在遇到不可重试错误时退出）、0 = 禁止重试、正整数 = 重试次数上限（允许大于 10）。缺省时回退到全局 gcmp.retry.maxAttempts。"
                },
                "initialDelayMs": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "初始重试延迟（毫秒）。缺省时回退到内置默认值 1000ms。"
                },
                "maxDelayMs": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "最大重试延迟上限（毫秒）。缺省时回退到内置默认值 15000ms。"
                }
            }
        }
    },
    "patternProperties": {
        "^retry\\..+": {
            "type": "object",
            "description": "子 provider 级别的重试配置覆盖（可选）。为指定子 provider（如 \"retry.xfyun-coding\"）配置独立的重试策略。字段语义与顶层 retry 一致：-1 无限重试、0 禁止重试、正整数不限上限。",
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "是否对该子 provider 启用重试。"
                },
                "maxAttempts": {
                    "anyOf": [{ "const": -1 }, { "const": 0 }, { "type": "integer", "minimum": 1 }],
                    "description": "该子 provider 的最大重试次数。-1 = 无限、0 = 禁用、正整数 = 上限。"
                },
                "initialDelayMs": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "该子 provider 的初始重试延迟（毫秒）。"
                },
                "maxDelayMs": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "该子 provider 的最大重试延迟上限（毫秒）。"
                }
            }
        }
    },
    "$defs": {
        "capabilities": {
            "type": "object",
            "additionalProperties": false,
            "required": ["toolCalling", "imageInput"],
            "properties": {
                "toolCalling": {
                    "type": "boolean",
                    "description": "模型是否可以执行工具/函数调用。"
                },
                "imageInput": {
                    "type": "boolean",
                    "description": "模型是否接受图像输入。"
                },
                "editTools": {
                    "description": "模型偏好的编辑工具列表，作为提示使用。true 时等价于默认集 [\"multi-find-replace\", \"find-replace\", \"code-rewrite\"]。可选值：find-replace | multi-find-replace | code-rewrite | apply-patch",
                    "anyOf": [
                        { "const": true },
                        {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": ["find-replace", "multi-find-replace", "code-rewrite", "apply-patch"]
                            },
                            "uniqueItems": true
                        }
                    ]
                }
            }
        },
        "webSearchToolConfig": {
            "type": "object",
            "additionalProperties": false,
            "description": "原生联网搜索工具的详细配置。maxUses 仅在 anthropic 模式下生效；allowedDomains、blockedDomains 和 userLocation 在 anthropic 与 openai-responses 模式下均生效。",
            "properties": {
                "maxUses": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "最大搜索次数（仅 anthropic 模式生效）。"
                },
                "allowedDomains": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "uniqueItems": true,
                    "description": "域名白名单，仅在这些域名中搜索。"
                },
                "blockedDomains": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "uniqueItems": true,
                    "description": "域名黑名单，搜索时排除这些域名。"
                },
                "userLocation": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "city": { "type": "string", "minLength": 1, "description": "用户所在城市" },
                        "region": { "type": "string", "minLength": 1, "description": "用户所在地区" },
                        "country": { "type": "string", "minLength": 1, "description": "ISO 国家代码" },
                        "timezone": { "type": "string", "minLength": 1, "description": "IANA 时区" }
                    },
                    "description": "用户近似位置，用于影响搜索结果的本地化。"
                }
            }
        },
        "nativeToolConfig": {
            "type": "object",
            "description": "原生工具配置项。仅 type 为必填，允许传入 provider 特有的额外选项（如 x_search、remote_mcp 等）。",
            "required": ["type"],
            "properties": {
                "type": {
                    "type": "string",
                    "minLength": 1,
                    "description": "原生工具类型（如 web_search、web_extractor、x_search、remote_mcp）。不限定枚举，允许任意字符串以兼容 provider 特有工具。"
                },
                "maxUses": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "最大搜索次数，默认 5（仅 anthropic 模式、web_search 生效）。"
                },
                "allowedDomains": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "uniqueItems": true,
                    "description": "域名白名单（仅 web_search 生效）。"
                },
                "blockedDomains": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "uniqueItems": true,
                    "description": "域名黑名单（仅 web_search 生效）。"
                },
                "userLocation": {
                    "type": "object",
                    "properties": {
                        "city": { "type": "string", "minLength": 1, "description": "用户所在城市" },
                        "region": { "type": "string", "minLength": 1, "description": "用户所在地区" },
                        "country": { "type": "string", "minLength": 1, "description": "ISO 国家代码" },
                        "timezone": { "type": "string", "minLength": 1, "description": "IANA 时区" }
                    },
                    "description": "用户近似位置（仅 web_search 生效）。"
                }
            }
        },
        "tokenPricing": {
            "description": "Token 定价信息，用于客户端成本估算和模型选择器展示。支持三种形式：(1) canonical 对象 { pricing, tiers? }；(2) 双币映射 { \"USD\": [...], \"RMB\": [...] }；(3) 数组简写 [inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]（默认 USD）。所有价格统一通过 pricing 数组或双币映射定义。",
            "oneOf": [
                {
                    "type": "object",
                    "description": "canonical tokenPricing 对象形式。编辑器保存时优先回写该形式。",
                    "additionalProperties": false,
                    "required": ["pricing"],
                    "properties": {
                        "pricing": {
                            "description": "原始数组简写输入或双币映射。数组格式：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]（USD）。双币映射格式：{ \"USD\": [...], \"RMB\": [...] }。",
                            "oneOf": [
                                {
                                    "type": "array",
                                    "description": "数组简写：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]（USD/百万 token）。",
                                    "minItems": 2,
                                    "maxItems": 4,
                                    "items": { "type": "number", "minimum": 0 }
                                },
                                {
                                    "type": "object",
                                    "description": "双币映射：USD 为主价格，RMB 为辅助显示价格。",
                                    "additionalProperties": false,
                                    "anyOf": [{ "required": ["USD"] }, { "required": ["RMB"] }],
                                    "properties": {
                                        "USD": {
                                            "type": "array",
                                            "description": "USD 价格数组：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]。",
                                            "minItems": 2,
                                            "maxItems": 4,
                                            "items": { "type": "number", "minimum": 0 }
                                        },
                                        "RMB": {
                                            "type": "array",
                                            "description": "RMB 价格数组：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]。",
                                            "minItems": 2,
                                            "maxItems": 4,
                                            "items": { "type": "number", "minimum": 0 }
                                        }
                                    }
                                }
                            ]
                        },
                        "tiers": {
                            "type": "array",
                            "description": "峰谷分档定价。首个命中条件的 tier 生效。若无 tier 命中，回退到上方的静态单档。每个 tier 必须包含至少一个匹配条件（cron/serviceTier/contextSizeMin），且价格必须全部通过 pricing 定义。",
                            "items": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["pricing"],
                                "anyOf": [
                                    { "required": ["cron"] },
                                    { "required": ["serviceTier"] },
                                    { "required": ["contextSizeMin"] }
                                ],
                                "properties": {
                                    "pricing": {
                                        "description": "该 tier 的定价输入：数组简写（USD）、双币映射，或数值倍率（相对顶层静态单档）。",
                                        "oneOf": [
                                            {
                                                "type": "array",
                                                "description": "该 tier 的原始数组简写输入（USD）。格式：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]。",
                                                "minItems": 2,
                                                "maxItems": 4,
                                                "items": { "type": "number", "minimum": 0 }
                                            },
                                            {
                                                "type": "object",
                                                "description": "该 tier 的双币映射：USD 为主价格，RMB 为辅助显示价格。",
                                                "additionalProperties": false,
                                                "anyOf": [{ "required": ["USD"] }, { "required": ["RMB"] }],
                                                "properties": {
                                                    "USD": {
                                                        "type": "array",
                                                        "description": "USD 价格数组：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]。",
                                                        "minItems": 2,
                                                        "maxItems": 4,
                                                        "items": { "type": "number", "minimum": 0 }
                                                    },
                                                    "RMB": {
                                                        "type": "array",
                                                        "description": "RMB 价格数组：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]。",
                                                        "minItems": 2,
                                                        "maxItems": 4,
                                                        "items": { "type": "number", "minimum": 0 }
                                                    }
                                                }
                                            },
                                            {
                                                "type": "number",
                                                "minimum": 0,
                                                "description": "该 tier 相对顶层静态单档的倍率。1 表示与顶层价格相同，1.5 表示各价格乘以 1.5。"
                                            }
                                        ]
                                    },
                                    "cron": {
                                        "type": "string",
                                        "pattern": "^(?:[0-9*][0-9*/,\\-]*)(?:\\s+(?:[0-9*][0-9*/,\\-]*)){4}$",
                                        "description": "Cron 表达式（5 字段：分 时 日 月 周），定义该档位生效时段。缺省为全时段（\"* * * * *\"）。用范围/通配表达时间窗口，如 \"* 9-23 * * 1-5\" = 工作日 9:00-23:59。默认按北京时间匹配。"
                                    },
                                    "timezone": {
                                        "type": "string",
                                        "description": "IANA 时区（如 \"Asia/Shanghai\"）。缺省为北京时间（UTC+8），因为峰谷定价主要面向国内服务商的计费规则。"
                                    },
                                    "serviceTier": {
                                        "type": "string",
                                        "description": "可选的服务等级匹配条件（如 \"priority\"）。设置后，仅当用户在 Chat UI 选择了匹配的 serviceTier 时此 tier 才生效；缺省则仅按时间匹配。用于\"按服务等级计费\"场景。"
                                    },
                                    "contextSizeMin": {
                                        "type": "number",
                                        "minimum": 0,
                                        "description": "可选的最小 input token 数。设置后，仅当实际消耗的 input token 数达到此值时该 tier 才生效（与 usage 对比，而非预分配窗口）。用于\"按上下文大小阶梯计费\"场景。"
                                    }
                                }
                            }
                        }
                    }
                },
                {
                    "type": "object",
                    "description": "双币映射简写：{ \"USD\": [...], \"RMB\": [...] }。USD 为主价格，RMB 为辅助显示。",
                    "additionalProperties": false,
                    "anyOf": [{ "required": ["USD"] }, { "required": ["RMB"] }],
                    "properties": {
                        "USD": {
                            "type": "array",
                            "description": "USD 价格数组：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]。",
                            "minItems": 2,
                            "maxItems": 4,
                            "items": { "type": "number", "minimum": 0 }
                        },
                        "RMB": {
                            "type": "array",
                            "description": "RMB 价格数组：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]。",
                            "minItems": 2,
                            "maxItems": 4,
                            "items": { "type": "number", "minimum": 0 }
                        }
                    }
                },
                {
                    "type": "array",
                    "description": "Token 定价简写形式：[inputPrice, outputPrice, cacheReadPrice?, cacheWritePrice?]（USD/百万 token）。支持 2~4 项数字。等价于不含 tiers 的对象形式。",
                    "minItems": 2,
                    "maxItems": 4,
                    "items": { "type": "number", "minimum": 0 }
                }
            ]
        },
        "model": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "tooltip", "maxInputTokens", "maxOutputTokens", "capabilities"],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "发送给提供商 API 的标识符。"
                },
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "在模型选择器中显示的名称。"
                },
                "tooltip": {
                    "type": "string",
                    "minLength": 1,
                    "description": "作为悬停工具提示显示的详细描述。"
                },
                "maxInputTokens": {
                    "type": "integer",
                    "minimum": 64000,
                    "description": "提供商接受的最大输入令牌数。最大输入Token数（input + output = context）"
                },
                "maxOutputTokens": {
                    "type": "integer",
                    "minimum": 128,
                    "maximum": 128000,
                    "description": "提供商在单个响应中可以生成的最大令牌数。内置 provider 配置限制为不超过 128K。Copilot暂不支持根据窗口调整此值，以一个最保守的值作为最大输出令牌数。"
                },
                "version": {
                    "type": "string",
                    "minLength": 1,
                    "description": "可选的提供商特定版本标签。"
                },
                "capabilities": {
                    "$ref": "#/$defs/capabilities"
                },
                "provider": {
                    "type": "string",
                    "minLength": 1,
                    "description": "模型特定的提供商标识符。用于指定该模型使用的提供商进行API密钥查找，使得同一提供商下的不同模型可以使用不同的API密钥。"
                },
                "sdkMode": {
                    "type": "string",
                    "enum": ["anthropic", "openai", "openai-sse", "openai-responses"],
                    "default": "openai",
                    "description": "SDK模式选择：使用 OpenAI SDK 或 Anthropic SDK 处理请求。"
                },
                "baseUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "覆盖提供商默认的可选模型特定基础 URL。"
                },
                "model": {
                    "type": "string",
                    "minLength": 1,
                    "description": "当与 ID 不同时的可选请求模型名称。"
                },
                "thinking": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": ["disabled", "enabled", "auto", "adaptive"],
                        "enumDescriptions": [
                            "强制关闭深度思考能力，模型不输出思维链内容",
                            "强制开启深度思考能力，模型强制输出思维链内容",
                            "模型自行判断是否需要进行深度思考",
                            "模型根据上下文自适应调整深度思考模式"
                        ]
                    },
                    "description": "深度思考配置，控制模型是否输出思维链内容"
                },
                "thinkingFormat": {
                    "type": "string",
                    "enum": ["boolean", "boolean-none", "object", "object-none", "effort-none"],
                    "enumDescriptions": [
                        "使用布尔值格式: { enable_thinking: true/false }",
                        "仅当 reasoningEffort 为 none 时传递布尔值 { enable_thinking: false }，其余情况忽略",
                        "使用对象格式: { thinking: { type: 'enabled' | 'disabled' } }",
                        "仅当 reasoningEffort 为 none 时传递 object 格式的禁用思考参数，其余情况忽略",
                        "当 reasoningEffort 为 none 时直接传递 { reasoning_effort: 'none' }，忽略思考参数"
                    ],
                    "default": "boolean",
                    "description": "思考模式参数的传递格式，用于兼容不同模型的API格式要求"
                },
                "reasoningFormat": {
                    "type": "string",
                    "enum": ["flat", "nested"],
                    "enumDescriptions": [
                        "平铺格式: { reasoning_effort: \"...\" }（默认）",
                        "嵌套格式: { reasoning: { effort: '...' } } — OpenAI 新版嵌套格式"
                    ],
                    "default": "flat",
                    "description": "API请求中 reasoning 参数的格式（仅 openai/openai-sse 模式生效）"
                },
                "reasoningEffort": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": ["none", "minimal", "low", "medium", "high", "xhigh", "max"],
                        "enumDescriptions": [
                            "关闭思考，直接回答",
                            "关闭思考，直接回答",
                            "轻量思考，侧重快速响应",
                            "均衡模式，兼顾速度与深度",
                            "深度分析，处理复杂问题",
                            "最大推理深度，速度较慢",
                            "绝对最高能力，对 token 消耗没有限制"
                        ]
                    },
                    "description": "调节思维链长度，平衡不同场景对效果、时延、成本的需求"
                },
                "reasoningDefault": {
                    "type": "string",
                    "enum": ["none", "minimal", "low", "medium", "high", "xhigh", "max"],
                    "enumDescriptions": [
                        "关闭思考，直接回答",
                        "关闭思考，直接回答",
                        "轻量思考，侧重快速响应",
                        "均衡模式，兼顾速度与深度",
                        "深度分析，处理复杂问题",
                        "最大推理深度，速度较慢",
                        "绝对最高能力，对 token 消耗没有限制"
                    ],
                    "description": "默认推理强度。指定时将覆盖“medium 优先 / 数组首项”规则，作为 reasoningEffort 的默认值。该值应包含在 reasoningEffort 数组中。"
                },
                "contextSize": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 1,
                        "description": "单个可选上下文窗口大小（token）"
                    },
                    "uniqueItems": true,
                    "description": "上下文窗口调节选项列表，按顺序决定模型 picker 的可选值和默认值，只需要填写数字数组"
                },
                "serviceTier": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": ["auto", "default", "flex", "priority"],
                        "enumDescriptions": [
                            "自动选择服务等级",
                            "标准处理速度",
                            "灵活处理，倍率更高",
                            "优先处理，倍率最高"
                        ]
                    },
                    "uniqueItems": true,
                    "description": "服务等级选项列表，用于调节响应速度与配额倍率。第一个值作为默认值。仅 openai-responses 和 anthropic 模式生效，default/auto 不传递 service_tier 到请求体。"
                },
                "customHeader": {
                    "type": "object",
                    "description": "可选的自定义HTTP头部，将在API请求中附加。",
                    "additionalProperties": {
                        "type": "string",
                        "description": "HTTP头部值",
                        "minLength": 1
                    }
                },
                "extraBody": {
                    "type": "object",
                    "description": "额外的请求体参数，将在API请求中合并到请求体中",
                    "additionalProperties": {
                        "description": "额外的请求体参数值"
                    }
                },
                "useInstructions": {
                    "type": "boolean",
                    "description": "是否在 Responses API 中使用 instructions 参数（可选）\n- false: 使用用户消息传递系统消息（默认）\n- true: 使用 instructions 参数传递系统消息",
                    "default": false
                },
                "webSearchTool": {
                    "description": "是否启用原生联网搜索工具（anthropic / openai-responses 模式生效）。为 true 时使用默认配置；也可传入详细配置对象。",
                    "oneOf": [{ "type": "boolean" }, { "$ref": "#/$defs/webSearchToolConfig" }],
                    "default": false
                },
                "nativeTools": {
                    "type": "array",
                    "description": "额外原生工具箱（可选）。补充注入 OpenAI Responses API 内置工具（如 web_extractor）。与 webSearchTool 叠加注入；若含 web_search 则以 nativeTools 为准。仅 openai-responses 生效；anthropic 仅取 web_search 项。",
                    "items": { "$ref": "#/$defs/nativeToolConfig" }
                },
                "tokenPricing": {
                    "$ref": "#/$defs/tokenPricing"
                }
            },
            "allOf": [
                {
                    "if": {
                        "anyOf": [
                            {
                                "properties": { "sdkMode": { "const": "anthropic" } },
                                "required": ["sdkMode"]
                            },
                            {
                                "properties": { "sdkMode": { "const": "openai-responses" } },
                                "required": ["sdkMode"]
                            }
                        ]
                    },
                    "then": {
                        "properties": {
                            "webSearchTool": {
                                "description": "启用原生联网搜索工具。anthropic 模式使用 Anthropic web_search_20250305；openai-responses 模式使用 Responses API web_search。为 true 时使用默认配置，也可传入详细配置对象。",
                                "oneOf": [{ "type": "boolean" }, { "$ref": "#/$defs/webSearchToolConfig" }],
                                "default": false
                            },
                            "nativeTools": {
                                "type": "array",
                                "description": "额外原生工具箱。openai-responses 模式注入 web_extractor 等内置工具；anthropic 模式仅取其中的 web_search 项。与 webSearchTool 叠加，若含 web_search 则以 nativeTools 为准。",
                                "items": { "$ref": "#/$defs/nativeToolConfig" }
                            }
                        }
                    },
                    "else": {
                        "properties": {
                            "webSearchTool": {
                                "deprecationMessage": "webSearchTool 仅对 anthropic 和 openai-responses 模式生效"
                            },
                            "nativeTools": {
                                "deprecationMessage": "nativeTools 仅对 anthropic 和 openai-responses 模式生效"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "sdkMode": {
                                "const": "openai-responses"
                            }
                        },
                        "required": ["sdkMode"]
                    },
                    "then": {
                        "properties": {
                            "useInstructions": {
                                "type": "boolean",
                                "description": "是否在 Responses API 中使用 instructions 参数（可选）\n- false: 使用用户消息传递系统消息（默认）\n- true: 使用 instructions 参数传递系统消息",
                                "default": false
                            }
                        }
                    },
                    "else": {
                        "properties": {
                            "useInstructions": {
                                "deprecationMessage": "useInstructions 仅对 openai-responses 模式生效"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "anyOf": [
                            { "not": { "required": ["sdkMode"] } },
                            { "properties": { "sdkMode": { "enum": ["openai", "openai-sse"] } } }
                        ]
                    },
                    "then": {
                        "properties": {
                            "thinkingFormat": {
                                "type": "string",
                                "enum": ["boolean", "boolean-none", "object", "object-none", "effort-none"],
                                "enumDescriptions": [
                                    "使用布尔值格式: { enable_thinking: true/false }",
                                    "仅当 reasoningEffort 为 none 时传递布尔值 { enable_thinking: false }，其余情况忽略",
                                    "使用对象格式: { thinking: { type: 'enabled' | 'disabled' } }",
                                    "仅当 reasoningEffort 为 none 时传递 object 格式的禁用思考参数，其余情况忽略",
                                    "当 reasoningEffort 为 none 时直接传递 { reasoning_effort: 'none' }，忽略思考参数"
                                ],
                                "default": "boolean",
                                "description": "思考模式参数的传递格式，用于兼容不同模型的API格式要求"
                            },
                            "reasoningFormat": {
                                "type": "string",
                                "enum": ["flat", "nested"],
                                "enumDescriptions": [
                                    "平铺格式: { reasoning_effort: \"...\" }（默认）",
                                    "嵌套格式: { reasoning: { effort: '...' } } — OpenAI 新版嵌套格式"
                                ],
                                "default": "flat",
                                "description": "API请求中 reasoning 参数的格式"
                            }
                        }
                    },
                    "else": {
                        "properties": {
                            "thinkingFormat": {
                                "deprecationMessage": "thinkingFormat 仅对 openai 和 openai-sse 模式生效"
                            },
                            "reasoningFormat": {
                                "deprecationMessage": "reasoningFormat 仅对 openai 和 openai-sse 模式生效"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "anyOf": [
                            {
                                "properties": {
                                    "sdkMode": {
                                        "const": "openai-responses"
                                    }
                                },
                                "required": ["sdkMode"]
                            },
                            {
                                "properties": {
                                    "sdkMode": {
                                        "const": "anthropic"
                                    }
                                },
                                "required": ["sdkMode"]
                            }
                        ]
                    },
                    "then": {
                        "properties": {
                            "serviceTier": {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "enum": ["auto", "default", "flex", "priority"]
                                },
                                "uniqueItems": true,
                                "description": "服务等级选项列表，用于调节响应速度与配额倍率。default/auto 不传递 service_tier 到请求体。"
                            }
                        }
                    },
                    "else": {
                        "properties": {
                            "serviceTier": {
                                "deprecationMessage": "serviceTier 仅对 openai-responses 和 anthropic 模式生效"
                            }
                        }
                    }
                }
            ]
        }
    }
}
