      "scm/title": [
        {
          "command": "gcmp.commit.generateMessage",
          "group": "navigation",
          "when": "config.git.enabled && scmProvider == git && gcmp.gitAvailable && gcmp.commitEnabled"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "gcmp.commit.generateMessageStaged",
          "when": "config.git.enabled && scmProvider == git && scmResourceGroup == index && gcmp.gitAvailable && gcmp.commitEnabled",
          "group": "inline@-3"
        },
        {
          "command": "gcmp.commit.generateMessageWorkingTree",
          "when": "config.git.enabled && scmProvider == git && scmResourceGroup == workingTree && gcmp.gitAvailable && gcmp.commitEnabled",
          "group": "inline@-3"
        }
      ]
    }
