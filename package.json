    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "watch": "node esbuild.config.js --watch --dev",
    "package": "vsce package",
    "publish": "vsce publish --allow-proposed-apis chatProvider",
    "pretest": "npm run compile:dev",
    "test": "npm run test:schema-sanitizer && npm run test:stateful-marker && npm run test:reasoning-replay && npm run test:copilot-usage",
    "test:copilot-usage": "tsx --test src/utils/copilotUsage.test.ts",
    "test:reasoning-replay": "tsx --test src/handlers/reasoningReplayPolicy.test.ts",
