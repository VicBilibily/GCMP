{
  "name": "gcmp",
  "publisher": "vicanent",
  "displayName": "AI Chat Models",
  "description": "%extension.description%",
  "version": "0.22.27-beta10",
  "license": "MIT",
  "keywords": [
    "ai",
    "chat",
    "copilot",
    "github-copilot",
    "language-model",
    "zhipu",
    "kimi",
    "volcengine",
    "minimax",
    "moonshot",
    "deepseek",
    "streamlake",
    "dashscope",
    "tencent",
    "Xiaomi MiMo",
    "baidu",
    "qianfan",
    "百度千帆",
    "OpenAI Compatible",
    "Anthropic Compatible",
    "智谱AI",
    "火山方舟",
    "月之暗面",
    "深度求索",
    "快手万擎",
    "阿里云百炼",
    "腾讯云",
    "百度千帆",
    "Coding Plan 编程套餐"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VicBilibily/GCMP.git"
  },
  "engines": {
    "vscode": ">=1.120.0",
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "extensionDependencies": ["github.copilot-chat"],
  "categories": ["AI", "Chat"],
  "icon": "./gcmp-logo.png",
  "main": "./dist/extension.js",
  "enabledApiProposals": ["chatProvider"],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelProvider:gcmp.zhipu",
    "onLanguageModelProvider:gcmp.minimax",
    "onLanguageModelProvider:gcmp.moonshot",
    "onLanguageModelProvider:gcmp.deepseek",
    "onLanguageModelProvider:gcmp.dashscope",
    "onLanguageModelProvider:gcmp.streamlake",
    "onLanguageModelProvider:gcmp.volcengine",
    "onLanguageModelProvider:gcmp.tencent",
    "onLanguageModelProvider:gcmp.xiaomimimo",
    "onLanguageModelProvider:gcmp.gemini",
    "onLanguageModelProvider:gcmp.codex",
    "onLanguageModelProvider:gcmp.baidu",
    "onLanguageModelProvider:gcmp.compatible",
    "onLanguageModelTool:gcmp_zhipuWebSearch",
    "onLanguageModelTool:gcmp_minimaxWebSearch",
    "onLanguageModelTool:gcmp_kimiWebSearch",
    "onLanguageModelTool:gcmp_dashscopeWebSearch",
    "onFileSystem:gcmp-settings"
  ],
