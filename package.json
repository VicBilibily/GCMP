  "repository": {
    "type": "git",
    "url": "https://github.com/VicBilibily/GCMP.git"
  },
  "engines": {
    "vscode": ">=1.125.0",
    "node": ">=22.22.3",
    "npm": ">=10.8.2"
  },
  "enabledApiProposals": ["chatProvider"],
  "extensionDependencies": ["github.copilot-chat"],
  "categories": ["AI", "Chat"],
  "icon": "./gcmp-logo.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelProvider:gcmp.zhipu",
    "onLanguageModelProvider:gcmp.minimax",
    "onLanguageModelProvider:gcmp.moonshot",
    "onLanguageModelProvider:gcmp.deepseek",
    "onLanguageModelProvider:gcmp.dashscope",
    "onLanguageModelProvider:gcmp.streamlake",
    "onLanguageModelProvider:gcmp.volcengine",
    "onLanguageModelProvider:gcmp.tencent",
    "onLanguageModelProvider:gcmp.xiaomimimo",
    "onLanguageModelProvider:gcmp.baidu",
    "onLanguageModelProvider:gcmp.stepfun",
    "onLanguageModelProvider:gcmp.antling",
    "onLanguageModelProvider:gcmp.xfyun",
    "onLanguageModelProvider:gcmp.longcat",
    "onLanguageModelProvider:gcmp.codex",
    "onLanguageModelProvider:gcmp.grok",
    "onLanguageModelProvider:gcmp.opencode",
    "onLanguageModelProvider:gcmp.hyper",
    "onLanguageModelProvider:gcmp.clinepass",
    "onLanguageModelProvider:gcmp.compatible",
    "onLanguageModelTool:gcmp_zhipuWebSearch",
    "onLanguageModelTool:gcmp_minimaxWebSearch",
    "onLanguageModelTool:gcmp_kimiWebSearch",
    "onLanguageModelTool:gcmp_dashscopeWebSearch",
    "onLanguageModelTool:gcmp_stepfunWebSearch",
    "onLanguageModelTool:gcmp_visionTool_uiToArtifact",
    "onLanguageModelTool:gcmp_visionTool_extractTextFromScreenshot",
    "onLanguageModelTool:gcmp_visionTool_diagnoseErrorScreenshot",
    "onLanguageModelTool:gcmp_visionTool_understandTechnicalDiagram",
    "onLanguageModelTool:gcmp_visionTool_analyzeDataVisualization",
    "onLanguageModelTool:gcmp_visionTool_uiDiffCheck",
    "onLanguageModelTool:gcmp_visionTool_analyzeImage",
    "onFileSystem:gcmp-settings"
  ],
