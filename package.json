    "configuration": {
      "title": "GCMP - AI Chat Models",
      "properties": {
        "gcmp.maxTokens": {
          "type": "number",
          "default": 32000,
          "minimum": 32,
          "maximum": 256000,
          "description": "%setting.maxTokens.description%",
          "scope": "application"
        },
        "gcmp.retry.maxAttempts": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 5,
          "description": "%setting.retry.maxAttempts.description%",
          "scope": "application"
        },
        "gcmp.temperature": {
          "type": "number",
          "deprecationMessage": "%setting.temperature.deprecationMessage%",
          "description": "%setting.temperature.description%",
          "scope": "application"
        },
        "gcmp.topP": {
          "type": "number",
          "deprecationMessage": "%setting.topP.deprecationMessage%",
          "description": "%setting.topP.description%",
          "scope": "application"
        },
        "gcmp.rememberLastModel": {
          "type": "boolean",
          "deprecationMessage": "%setting.rememberLastModel.deprecationMessage%",
          "description": "%setting.rememberLastModel.description%",
          "scope": "application"
        },
        "gcmp.editToolMode": {
          "type": "string",
          "enum": ["claude", "gpt-5", "none"],
          "enumDescriptions": [
            "%setting.editToolMode.enumDescriptions.claude%",
            "%setting.editToolMode.enumDescriptions.gpt5%",
            "%setting.editToolMode.enumDescriptions.none%"
          ],
          "default": "claude",
          "deprecationMessage": "%setting.editToolMode.deprecationMessage%",
          "description": "%setting.editToolMode.description%",
          "scope": "application"
        },
        "gcmp.autoPrefixModelId": {
          "type": "boolean",
          "default": true,
          "description": "%setting.autoPrefixModelId.description%",
          "scope": "application",
          "deprecationMessage": "%setting.autoPrefixModelId.deprecationMessage%"
        },
        "gcmp.zhipu.search.enableMCP": {
          "type": "boolean",
          "default": true,
          "description": "%setting.zhipu.search.enableMCP.description%",
          "scope": "application"
        },
        "gcmp.zhipu.endpoint": {
          "type": "string",
          "enum": ["open.bigmodel.cn", "api.z.ai"],
          "default": "open.bigmodel.cn",
          "description": "%setting.zhipu.endpoint.description%",
          "scope": "application"
        },
        "gcmp.minimax.endpoint": {
          "type": "string",
          "enum": ["minimaxi.com", "minimax.io"],
          "default": "minimaxi.com",
          "description": "%setting.minimax.endpoint.description%",
          "scope": "application"
        },
        "gcmp.xiaomimimo.endpoint": {
          "type": "string",
          "enum": ["cn", "sgp", "ams"],
          "default": "cn",
          "description": "%setting.xiaomimimo.endpoint.description%",
          "scope": "application"
        },
        "gcmp.usages.retentionDays": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 365,
          "description": "%setting.usages.retentionDays.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%setting.fimCompletion.enabled.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 1000,
          "description": "%setting.fimCompletion.debounceMs.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.timeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "%setting.fimCompletion.timeoutMs.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.modelConfig": {
          "type": "object",
          "default": {
            "provider": "",
            "baseUrl": "",
            "model": ""
          },
          "description": "%setting.fimCompletion.modelConfig.description%",
          "scope": "application",
          "properties": {
            "provider": {
              "type": "string",
              "description": "%setting.modelConfig.provider.description%"
            },
            "baseUrl": {
              "type": "string",
              "description": "%setting.modelConfig.baseUrl.description%",
              "format": "uri"
            },
            "model": {
              "type": "string",
              "description": "%setting.fimCompletion.modelConfig.model.description%"
            },
            "maxTokens": {
              "type": "number",
              "description": "%setting.fimCompletion.modelConfig.maxTokens.description%",
              "default": 200,
              "minimum": 50,
              "maximum": 16000
            },
            "extraBody": {
              "type": "object",
              "description": "%setting.modelConfig.extraBody.description%",
              "additionalProperties": {
                "description": "%setting.modelConfig.extraBody.additionalProperties.description%"
              }
            }
          },
          "required": ["provider", "baseUrl", "model"]
        },
        "gcmp.nesCompletion.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%setting.nesCompletion.enabled.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 1000,
          "description": "%setting.nesCompletion.debounceMs.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.timeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "%setting.nesCompletion.timeoutMs.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.manualOnly": {
          "type": "boolean",
          "default": false,
          "description": "%setting.nesCompletion.manualOnly.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.modelConfig": {
          "type": "object",
          "default": {
            "provider": "",
            "baseUrl": "",
            "model": ""
          },
          "description": "%setting.nesCompletion.modelConfig.description%",
          "scope": "application",
          "properties": {
            "provider": {
              "type": "string",
              "description": "%setting.modelConfig.provider.description%"
            },
            "baseUrl": {
              "type": "string",
              "description": "%setting.modelConfig.baseUrl.description%",
              "format": "uri"
            },
            "model": {
              "type": "string",
              "description": "%setting.nesCompletion.modelConfig.model.description%"
            },
            "maxTokens": {
              "type": "number",
              "description": "%setting.nesCompletion.modelConfig.maxTokens.description%",
              "default": 200,
              "minimum": 50,
              "maximum": 16000
            },
            "extraBody": {
              "type": "object",
              "description": "%setting.modelConfig.extraBody.description%",
              "additionalProperties": {
                "description": "%setting.modelConfig.extraBody.additionalProperties.description%"
              }
            }
          },
          "required": ["provider", "baseUrl", "model"]
        },
        "gcmp.commit.language": {
          "type": "string",
          "enum": ["chinese", "english"],
          "enumDescriptions": [
            "%setting.commit.language.enumDescriptions.chinese%",
            "%setting.commit.language.enumDescriptions.english%"
          ],
          "default": "chinese",
          "description": "%setting.commit.language.description%",
          "scope": "window"
        },
        "gcmp.commit.format": {
          "type": "string",
          "enum": [
            "auto",
            "plain",
            "custom",
            "conventional",
            "angular",
            "karma",
            "semantic",
            "emoji",
            "emojiKarma",
            "google",
            "atom"
          ],
          "enumDescriptions": [
            "%setting.commit.format.enumDescriptions.auto%",
            "%setting.commit.format.enumDescriptions.plain%",
            "%setting.commit.format.enumDescriptions.custom%",
            "%setting.commit.format.enumDescriptions.conventional%",
            "%setting.commit.format.enumDescriptions.angular%",
            "%setting.commit.format.enumDescriptions.karma%",
            "%setting.commit.format.enumDescriptions.semantic%",
            "%setting.commit.format.enumDescriptions.emoji%",
            "%setting.commit.format.enumDescriptions.emojiKarma%",
            "%setting.commit.format.enumDescriptions.google%",
            "%setting.commit.format.enumDescriptions.atom%"
          ],
          "default": "auto",
          "description": "%setting.commit.format.description%",
          "scope": "window"
        },
        "gcmp.commit.customInstructions": {
          "type": "string",
          "default": "",
          "description": "%setting.commit.customInstructions.description%",
          "scope": "window"
        },
        "gcmp.commit.model": {
          "type": "object",
          "default": {
            "provider": "",
            "model": ""
          },
          "description": "%setting.commit.model.description%",
          "scope": "window",
          "properties": {
            "provider": {
              "type": "string",
              "description": "%setting.commit.model.provider.description%"
            },
            "model": {
              "type": "string",
              "description": "%setting.commit.model.model.description%"
            }
          },
          "required": ["provider", "model"]
        },
        "gcmp.providerOverrides": {
          "type": "object",
          "default": {},
          "description": "%setting.providerOverrides.description%",
          "scope": "application"
        },
        "gcmp.compatibleModels": {
          "type": "array",
          "default": [],
          "description": "%setting.compatibleModels.description%",
          "scope": "application"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "settings.json",
        "url": "gcmp-settings://root/schema.json"
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "gcmp.zhipu",
        "displayName": "GCMP · ZhipuAI",
        "managementCommand": "gcmp.zhipu.configWizard"
      },
      {
        "vendor": "gcmp.minimax",
        "displayName": "GCMP · MiniMax",
        "managementCommand": "gcmp.minimax.configWizard"
      },
      {
        "vendor": "gcmp.moonshot",
        "displayName": "GCMP · MoonshotAI",
        "managementCommand": "gcmp.moonshot.configWizard"
      },
      {
        "vendor": "gcmp.deepseek",
        "displayName": "GCMP · DeepSeek",
        "managementCommand": "gcmp.deepseek.setApiKey"
      },
      {
        "vendor": "gcmp.dashscope",
        "displayName": "GCMP · AliDashScope",
        "managementCommand": "gcmp.dashscope.configWizard"
      },
      {
        "vendor": "gcmp.streamlake",
        "displayName": "GCMP · StreamLake",
        "managementCommand": "gcmp.streamlake.setApiKey"
      },
      {
        "vendor": "gcmp.volcengine",
        "displayName": "GCMP · Volcengine",
        "managementCommand": "gcmp.volcengine.configWizard"
      },
      {
        "vendor": "gcmp.tencent",
        "displayName": "GCMP · Tencent",
        "managementCommand": "gcmp.tencent.configWizard"
      },
      {
        "vendor": "gcmp.xiaomimimo",
        "displayName": "GCMP · Xiaomi MiMo",
        "managementCommand": "gcmp.xiaomimimo.configWizard"
      },
      {
        "vendor": "gcmp.baidu",
        "displayName": "GCMP · Baidu Qianfan",
        "managementCommand": "gcmp.baidu.configWizard"
      },
      {
        "vendor": "gcmp.gemini",
        "displayName": "GCMP · Gemini CLI",
        "managementCommand": "gcmp.gemini.configWizard"
      },
      {
        "vendor": "gcmp.codex",
        "displayName": "GCMP · Codex CLI",
        "managementCommand": "gcmp.codex.configWizard"
      },
      {
        "vendor": "gcmp.compatible",
        "displayName": "GCMP · OpenAI / Anthropic Compatible",
        "managementCommand": "gcmp.compatible.manageModels"
      }
    ],
    "languageModelTools": [
      {
        "name": "gcmp_zhipuWebSearch",
        "displayName": "%tool.zhipuWebSearch.displayName%",
        "toolReferenceName": "zhipuWebSearch",
        "modelDescription": "%tool.zhipuWebSearch.modelDescription%",
        "userDescription": "%tool.zhipuWebSearch.userDescription%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "search_query": {
              "type": "string",
              "description": "%tool.zhipuWebSearch.input.searchQuery.description%"
            },
            "search_engine": {
              "type": "string",
              "enum": [
                "search_std",
                "search_pro",
                "search_pro_sogou",
                "search_pro_quark"
              ],
              "description": "%tool.zhipuWebSearch.input.searchEngine.description%",
              "default": "search_std"
            },
            "search_intent": {
              "type": "boolean",
              "description": "%tool.zhipuWebSearch.input.searchIntent.description%",
              "default": false
            },
            "count": {
              "type": "integer",
              "description": "%tool.zhipuWebSearch.input.count.description%",
              "minimum": 1,
              "maximum": 20,
              "default": 10
            },
            "search_domain_filter": {
              "type": "string",
              "description": "%tool.zhipuWebSearch.input.searchDomainFilter.description%"
            },
            "search_recency_filter": {
              "type": "string",
              "enum": ["noLimit", "day", "week", "month", "year"],
              "description": "%tool.zhipuWebSearch.input.searchRecencyFilter.description%",
              "default": "noLimit"
            },
            "content_size": {
              "type": "string",
              "enum": ["low", "medium", "high"],
              "description": "%tool.zhipuWebSearch.input.contentSize.description%",
              "default": "medium"
            }
          },
          "required": ["search_query"]
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "gcmp_minimaxWebSearch",
        "displayName": "%tool.minimaxWebSearch.displayName%",
        "toolReferenceName": "minimaxWebSearch",
        "modelDescription": "%tool.minimaxWebSearch.modelDescription%",
        "userDescription": "%tool.minimaxWebSearch.userDescription%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "q": {
              "type": "string",
              "description": "%tool.minimaxWebSearch.input.q.description%"
            }
          },
          "required": ["q"]
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "gcmp_kimiWebSearch",
        "displayName": "%tool.kimiWebSearch.displayName%",
        "toolReferenceName": "kimiWebSearch",
        "modelDescription": "%tool.kimiWebSearch.modelDescription%",
        "userDescription": "%tool.kimiWebSearch.userDescription%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "%tool.kimiWebSearch.input.query.description%"
            },
            "limit": {
              "type": "integer",
              "description": "%tool.kimiWebSearch.input.limit.description%",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            },
            "includeContent": {
              "type": "boolean",
              "description": "%tool.kimiWebSearch.input.includeContent.description%",
              "default": false
            }
          },
