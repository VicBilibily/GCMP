{
    "name": "gcmp",
    "publisher": "vicanent",
    "displayName": "AI Chat Models",
    "description": "为 GitHub Copilot Chat 提供 智谱AI、MoonshotAI、心流AI 模型支持的扩展",
    "version": "0.3.0",
    "license": "MIT",
    "keywords": [
        "ai",
        "chat",
        "copilot",
        "github-copilot",
        "language-model",
        "zhipu",
        "moonshot",
        "iflow",
        "智谱",
        "月之暗面",
        "心流"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/VicBilibily/gcmp.git"
    },
    "engines": {
        "vscode": "^1.104.0",
        "node": ">=20.0.0",
        "npm": ">=9.0.0"
    },
    "categories": [
        "AI",
        "Chat"
    ],
    "icon": "./gcmp-logo.png",
    "main": "./dist/extension.js",
    "enabledApiProposals": [
        "chatProvider",
        "textDocumentChangeReason"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguageModelProvider:gcmp.zhipu",
        "onLanguageModelProvider:gcmp.moonshot",
        "onLanguageModelProvider:gcmp.iflow",
        "onLanguageModelTool:gcmp_zhipuWebSearch",
        "onLanguageModelTool:gcmp_applyDiffV2"
    ],
    "contributes": {
        "commands": [
            {
                "command": "gcmp.zhipu.setApiKey",
                "title": "设置 智谱AI API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.moonshot.setApiKey",
                "title": "设置 MoonshotAI API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.iflow.setApiKey",
                "title": "设置 心流AI API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.applyDiff",
                "title": "应用 Diff",
                "category": "GCMP",
                "icon": "$(diff)"
            },
            {
                "command": "gcmp.previewDiff",
                "title": "预览 Diff",
                "category": "GCMP",
                "icon": "$(preview)"
            },
            {
                "command": "gcmp.applyDiffV2.demo",
                "title": "Apply Diff V2 演示",
                "category": "GCMP",
                "icon": "$(rocket)"
            },
            {
                "command": "gcmp.applyDiffV2.createTest",
                "title": "创建测试 Diff",
                "category": "GCMP",
                "icon": "$(diff-added)"
            },
            {
                "command": "gcmp.tools.diagnostic",
                "title": "工具诊断",
                "category": "GCMP",
                "icon": "$(pulse)"
            },
            {
                "command": "gcmp.applyDiffV2.createEmptyLineTest",
                "title": "创建空行测试文件",
                "category": "GCMP",
                "icon": "$(test-view-icon)"
            },
            {
                "command": "gcmp.applyDiffFromClipboard",
                "title": "从剪贴板应用 Diff",
                "category": "GCMP",
                "icon": "$(clippy)"
            },
            {
                "command": "gcmp.showChatModificationHistory",
                "title": "GCMP: 显示聊天修改历史"
            },
            {
                "command": "gcmp.clearChatModificationHistory",
                "title": "GCMP: 清理聊天修改历史"
            }
        ],
        "configuration": {
            "title": "GCMP - AI Chat Models",
            "properties": {
                "gcmp.temperature": {
                    "type": "number",
                    "default": 0.1,
                    "minimum": 0,
                    "maximum": 2,
                    "description": "控制AI模型输出的随机性。较低的值（如0.1）产生更确定性的输出，较高的值（如1.0）产生更有创意的输出。",
                    "scope": "application"
                },
                "gcmp.topP": {
                    "type": "number",
                    "default": 1,
                    "minimum": 0,
                    "maximum": 1,
                    "description": "控制AI模型输出的多样性。使用较小的值（如0.9）会减少输出的随机性。",
                    "scope": "application"
                },
                "gcmp.maxTokens": {
                    "type": "number",
                    "default": 8192,
                    "minimum": 32,
                    "maximum": 32768,
                    "description": "控制AI模型输出的最大token数量。较大的值允许更长的响应。",
                    "scope": "application"
                },
                "gcmp.contextReduction": {
                    "type": "string",
                    "default": "1x",
                    "enum": [
                        "1x",
                        "1/2",
                        "1/4",
                        "1/8"
                    ],
                    "enumDescriptions": [
                        "完整上下文（128K/256K）- 保持完整理解能力",
                        "缩减至1/2（64K/128K）- 平衡理解能力与处理效率",
                        "缩减至1/4（32K/64K）- 专注于近期对话内容",
                        "缩减至1/8（16K/32K）- 仅保留最关键信息"
                    ],
                    "description": "控制AI模型可接受的上下文长度。缩减上下文可以提升处理效率，专注于更相关的信息，但可能影响模型对长对话历史的理解能力。修改此设置需要重启 VS Code 生效。",
                    "scope": "window"
                },
                "gcmp.moonshot.webSearch": {
                    "type": "boolean",
                    "default": false,
                    "description": "为 MoonshotAI 模型启用 Kimi 内置的 $web_search 联网搜索工具。开启后，AI 将能够通过官方内置工具获取实时信息来回答问题。注意：搜索结果会计入 prompt_tokens，每次搜索额外收费 ¥0.03。",
                    "scope": "application"
                },
                "gcmp.applyDiff.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "启用 Apply Diff 工具 (V1)。此工具允许 AI 模型精准应用 diff 格式的文件修改，包含文件备份和回滚机制。出于安全考虑，默认禁用。",
                    "scope": "application"
                },
                "gcmp.applyDiff.v2Enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "启用 Apply Diff V2 工具。全新重构版本，具有更好的 VS Code 集成、聊天修改历史跟踪、智能预览等功能。推荐使用。",
                    "scope": "application"
                }
            }
        },
        "languageModelChatProviders": [
            {
                "vendor": "gcmp.zhipu",
                "displayName": "[GCMP] 智谱AI",
                "managementCommand": "gcmp.zhipu.setApiKey"
            },
            {
                "vendor": "gcmp.moonshot",
                "displayName": "[GCMP] MoonshotAI",
                "managementCommand": "gcmp.moonshot.setApiKey"
            },
            {
                "vendor": "gcmp.iflow",
                "displayName": "[GCMP] 心流AI",
                "managementCommand": "gcmp.iflow.setApiKey"
            }
        ],
        "languageModelTools": [
            {
                "name": "gcmp_zhipuWebSearch",
                "displayName": "智谱AI网络搜索",
                "toolReferenceName": "zhipuWebSearch",
                "modelDescription": "使用智谱AI提供的网络搜索功能获取实时信息。支持多种搜索引擎：search_std（标准搜索，¥0.01）、search_pro（高级搜索，¥0.03）、search_pro_sogou（搜狗搜索，¥0.05）、search_pro_quark（夸克搜索，¥0.05）。",
                "userDescription": "通过智谱AI搜索网络获取最新信息",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "search_query": {
                            "type": "string",
                            "description": "搜索查询字符串"
                        },
                        "search_engine": {
                            "type": "string",
                            "enum": [
                                "search_std",
                                "search_pro",
                                "search_pro_sogou",
                                "search_pro_quark"
                            ],
                            "description": "搜索引擎类型：search_std（标准，¥0.01）、search_pro（高级，¥0.03）、search_pro_sogou（搜狗，¥0.05）、search_pro_quark（夸克，¥0.05）",
                            "default": "search_std"
                        },
                        "search_intent": {
                            "type": "boolean",
                            "description": "是否进行搜索意图分析",
                            "default": false
                        },
                        "count": {
                            "type": "integer",
                            "description": "返回搜索结果数量",
                            "minimum": 1,
                            "maximum": 20,
                            "default": 10
                        },
                        "search_domain_filter": {
                            "type": "string",
                            "description": "域名过滤器，限制搜索特定网站"
                        },
                        "search_recency_filter": {
                            "type": "string",
                            "enum": [
                                "noLimit",
                                "day",
                                "week",
                                "month",
                                "year"
                            ],
                            "description": "时间过滤器：noLimit（无限制）、day（一天内）、week（一周内）、month（一月内）、year（一年内）",
                            "default": "noLimit"
                        },
                        "content_size": {
                            "type": "string",
                            "enum": [
                                "low",
                                "medium",
                                "high"
                            ],
                            "description": "内容详细程度：low（低）、medium（中）、high（高）",
                            "default": "medium"
                        }
                    },
                    "required": [
                        "search_query"
                    ]
                },
                "canBeReferencedInPrompt": true
            },
            {
                "name": "gcmp_applyDiff",
                "displayName": "应用 Diff 修改",
                "toolReferenceName": "applyDiff",
                "modelDescription": "**精准文件修改工具** - 当需要对现有文件进行精确修改时使用。支持基于行号的精准编辑，包含安全备份机制。\n\n**何时使用**：\n- 用户明确要求修改特定文件的内容\n- 需要对代码进行局部调整或bug修复\n- 添加新功能或修改现有功能的实现\n- 用户提供了具体的修改要求和目标文件\n\n**使用原则**：\n1. 必须先读取目标文件内容确认当前状态\n2. 确保SEARCH内容与文件实际内容完全匹配\n3. 行号必须准确（从1开始计数）\n4. 对于重要修改建议先使用preview模式\n5. 支持单个diff中包含多个SEARCH/REPLACE块\n\n**格式要求**：严格遵循SEARCH/REPLACE格式，包含准确的行号和完整的原始内容匹配。",
                "userDescription": "智能应用代码差异修改，支持精准的文件编辑和安全回滚",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string",
                            "description": "目标文件路径（绝对路径或相对于工作区的路径）。示例：'src/components/Button.vue' 或 'C:\\\\project\\\\file.ts'"
                        },
                        "diff": {
                            "type": "string",
                            "description": "diff修改内容，使用严格的SEARCH/REPLACE格式：\n\n格式模板：\n<<<<<<< SEARCH\n:start_line:起始行号\n:end_line:结束行号\n-------\n要查找和替换的原始内容（必须与文件内容完全匹配）\n=======\n替换后的新内容\n>>>>>>> REPLACE\n\n支持多个块：可以在同一个diff中包含多个SEARCH/REPLACE块来同时修改多个地方。\n\n重要提示：\n- 行号从1开始计数\n- 原始内容必须与文件中的内容完全匹配（包括空格、缩进）\n- 如果是单行修改，start_line和end_line使用相同数字\n- 确保语法正确，特别是代码文件的修改"
                        },
                        "preview": {
                            "type": "boolean",
                            "description": "预览模式：设为true时只显示将要进行的修改，不实际修改文件。建议对重要文件或大幅修改先启用预览。",
                            "default": false
                        },
                        "requireConfirmation": {
                            "type": "boolean",
                            "description": "是否需要用户确认：设为true时会弹出确认对话框。对于重要文件修改建议启用此选项。",
                            "default": true
                        }
                    },
                    "required": [
                        "path",
                        "diff"
                    ]
                },
                "canBeReferencedInPrompt": true
            },
            {
                "name": "gcmp_applyDiffV2",
                "displayName": "应用 Diff 修改 V2",
                "toolReferenceName": "applyDiffV2",
                "modelDescription": "**新一代精准文件修改工具** - 基于 VS Code 深度集成重构的文件修改工具，具有聊天修改历史追踪、智能内容匹配和增强预览功能。\n\n**主要优势**：\n- **VS Code 原生集成**：完美融入编辑器，支持撤销/重做\n- **聊天历史追踪**：自动记录到聊天修改历史\n- **智能匹配**：支持精确匹配和模糊匹配\n- **实时预览**：使用 VS Code 内置 diff 查看器\n- **批量操作**：高效处理多个修改块\n- **安全机制**：增强的错误处理和恢复\n\n**何时使用**：\n- 需要对代码进行精确修改和重构\n- 要求修改历史可追踪和可撤销\n- 处理复杂的多块文件修改\n- 需要智能内容匹配的场景\n\n**格式要求**：使用标准的 SEARCH/REPLACE 格式，支持行号指定和智能匹配。推荐使用此 V2 版本以获得最佳体验。",
                "userDescription": "新一代智能文件修改工具，具有 VS Code 深度集成、聊天历史追踪和智能预览功能",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string",
                            "description": "目标文件路径（绝对路径或相对于工作区的路径）。支持智能路径解析和自动工作区检测。"
                        },
                        "diff": {
                            "type": "string",
                            "description": "diff修改内容，使用增强的SEARCH/REPLACE格式：\n\n基本格式：\n<<<<<<< SEARCH\n:start_line:起始行号\n:end_line:结束行号\n-------\n要查找的原始内容（支持智能匹配）\n=======\n替换后的新内容\n>>>>>>> REPLACE\n\n增强特性：\n- **智能匹配**：自动处理空格、缩进差异\n- **置信度评估**：自动评估匹配可靠性\n- **语言检测**：自动识别编程语言\n- **多块支持**：单个 diff 中支持多个 SEARCH/REPLACE 块\n- **插入操作**：支持在文件开头或指定位置插入内容\n\n重要提示：\n- 行号从1开始，支持智能行号调整\n- 原始内容支持模糊匹配和精确匹配\n- 自动语法验证和错误恢复"
                        },
                        "preview": {
                            "type": "boolean",
                            "description": "预览模式：启用时使用 VS Code 内置 diff 查看器显示修改预览，不实际修改文件。强烈建议对重要修改启用预览。",
                            "default": false
                        },
                        "batch": {
                            "type": "boolean",
                            "description": "批量模式：优化多文件或大量修改的处理性能。适用于重构或批量更新场景。",
                            "default": false
                        },
                        "suggest": {
                            "type": "boolean",
                            "description": "建议模式：返回编辑建议而不是直接应用，显示 Apply/Discard 按钮。从聊天调用时默认启用此模式以提供最佳用户体验。",
                            "default": false
                        }
                    },
                    "required": [
                        "path",
                        "diff"
                    ]
                },
                "canBeReferencedInPrompt": true
            }
        ]
    },
    "kiloCodeHeaders": {
        "HTTP-Referer": "https://kilocode.ai",
        "X-Title": "Kilo Code",
        "X-KiloCode-Version": "4.93.2",
        "User-Agent": "Kilo-Code/4.93.2"
    },
