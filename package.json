    "configuration": {
      "title": "GCMP - AI Chat Models",
      "properties": {
        "gcmp.proxy": {
          "type": "string",
          "default": "",
          "description": "%setting.proxy.description%",
          "anyOf": [
            {
              "const": ""
            },
            {
              "const": "noproxy"
            },
            {
              "format": "uri"
            },
            {
              "pattern": "^(?:(?:[^:@/\\s]+(?::[^@/\\s]*)?@)?(?:\\[[0-9A-Fa-f:.]+\\]|[^:/\\s?#]+)(?::\\d{1,5})?)$"
            }
          ],
          "scope": "machine"
        },
        "gcmp.tls.useSystemCertificates": {
          "type": "boolean",
          "default": true,
          "description": "%setting.tls.useSystemCertificates.description%",
          "scope": "application"
        },
        "gcmp.maxTokens": {
          "type": "number",
          "default": 32000,
          "minimum": 32,
          "maximum": 256000,
          "description": "%setting.maxTokens.description%",
          "deprecationMessage": "%setting.maxTokens.deprecation%",
          "scope": "application"
        },
        "gcmp.retry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%setting.retry.enabled.description%",
          "scope": "application"
        },
        "gcmp.retry.maxAttempts": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 5,
          "description": "%setting.retry.maxAttempts.description%",
          "scope": "application"
        },
        "gcmp.temperature": {
          "type": "number",
          "deprecationMessage": "%setting.temperature.deprecationMessage%",
          "description": "%setting.temperature.description%",
          "scope": "application"
        },
        "gcmp.topP": {
          "type": "number",
          "deprecationMessage": "%setting.topP.deprecationMessage%",
          "description": "%setting.topP.description%",
          "scope": "application"
        },
        "gcmp.rememberLastModel": {
          "type": "boolean",
          "deprecationMessage": "%setting.rememberLastModel.deprecationMessage%",
          "description": "%setting.rememberLastModel.description%",
          "scope": "application"
        },
        "gcmp.editToolMode": {
          "type": "string",
          "enum": ["claude", "gpt-5", "none"],
          "enumDescriptions": [
            "%setting.editToolMode.enumDescriptions.claude%",
            "%setting.editToolMode.enumDescriptions.gpt5%",
            "%setting.editToolMode.enumDescriptions.none%"
          ],
          "default": "claude",
          "deprecationMessage": "%setting.editToolMode.deprecationMessage%",
          "description": "%setting.editToolMode.description%",
          "scope": "application"
        },
        "gcmp.autoPrefixModelId": {
          "type": "boolean",
          "default": true,
          "description": "%setting.autoPrefixModelId.description%",
          "scope": "application",
          "deprecationMessage": "%setting.autoPrefixModelId.deprecationMessage%"
        },
        "gcmp.zhipu.search.enableMCP": {
          "type": "boolean",
          "default": true,
          "description": "%setting.zhipu.search.enableMCP.description%",
          "scope": "application"
        },
        "gcmp.zhipu.endpoint": {
          "type": "string",
          "enum": ["open.bigmodel.cn", "api.z.ai"],
          "default": "open.bigmodel.cn",
          "description": "%setting.zhipu.endpoint.description%",
          "scope": "application"
        },
        "gcmp.stepfun.search.enableMCP": {
          "type": "boolean",
          "default": true,
          "description": "%setting.stepfun.search.enableMCP.description%",
          "scope": "application"
        },
        "gcmp.minimax.endpoint": {
          "type": "string",
          "enum": ["minimaxi.com", "minimax.io"],
          "default": "minimaxi.com",
          "description": "%setting.minimax.endpoint.description%",
          "scope": "application"
        },
        "gcmp.xiaomimimo.endpoint": {
          "type": "string",
          "enum": ["cn", "sgp", "ams"],
          "default": "cn",
          "description": "%setting.xiaomimimo.endpoint.description%",
          "scope": "application"
        },
        "gcmp.usages.retentionDays": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 365,
          "description": "%setting.usages.retentionDays.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%setting.fimCompletion.enabled.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 1000,
          "description": "%setting.fimCompletion.debounceMs.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.timeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "%setting.fimCompletion.timeoutMs.description%",
          "scope": "application"
        },
        "gcmp.fimCompletion.circuitBreaker": {
          "type": "object",
          "default": {
            "enabled": true,
            "failureThreshold": 10,
            "cooldownSeconds": 30
          },
          "description": "%setting.fimCompletion.circuitBreaker.description%",
          "scope": "application",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "%setting.fimCompletion.circuitBreaker.enabled.description%"
            },
            "failureThreshold": {
              "type": "number",
              "default": 10,
              "minimum": 2,
              "maximum": 60,
              "description": "%setting.fimCompletion.circuitBreaker.failureThreshold.description%"
            },
            "cooldownSeconds": {
              "type": "number",
              "default": 30,
              "minimum": 10,
              "maximum": 300,
              "description": "%setting.fimCompletion.circuitBreaker.cooldownSeconds.description%"
            }
          }
        },
        "gcmp.fimCompletion.modelConfig": {
          "type": "object",
          "default": {
            "provider": "",
            "baseUrl": "",
            "model": ""
          },
          "description": "%setting.fimCompletion.modelConfig.description%",
          "scope": "application",
          "properties": {
            "provider": {
              "type": "string",
              "description": "%setting.modelConfig.provider.description%"
            },
            "baseUrl": {
              "type": "string",
              "description": "%setting.modelConfig.baseUrl.description%",
              "format": "uri"
            },
            "proxy": {
              "type": "string",
              "description": "%setting.modelConfig.proxy.description%",
              "anyOf": [
                {
                  "const": ""
                },
                {
                  "const": "noproxy"
                },
                {
                  "format": "uri"
                },
                {
                  "pattern": "^(?:(?:[^:@/\\s]+(?::[^@/\\s]*)?@)?(?:\\[[0-9A-Fa-f:.]+\\]|[^:/\\s?#]+)(?::\\d{1,5})?)$"
                }
              ]
            },
            "model": {
              "type": "string",
              "description": "%setting.fimCompletion.modelConfig.model.description%"
            },
            "maxTokens": {
              "type": "number",
              "description": "%setting.fimCompletion.modelConfig.maxTokens.description%",
              "default": 200,
              "minimum": 50,
              "maximum": 16000
            },
            "extraBody": {
              "type": "object",
              "description": "%setting.modelConfig.extraBody.description%",
              "additionalProperties": {
                "description": "%setting.modelConfig.extraBody.additionalProperties.description%"
              }
            }
          },
          "required": ["provider", "baseUrl", "model"]
        },
        "gcmp.nesCompletion.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%setting.nesCompletion.enabled.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 1000,
          "description": "%setting.nesCompletion.debounceMs.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.timeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "%setting.nesCompletion.timeoutMs.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.manualOnly": {
          "type": "boolean",
          "default": false,
          "description": "%setting.nesCompletion.manualOnly.description%",
          "scope": "application"
        },
        "gcmp.nesCompletion.circuitBreaker": {
          "type": "object",
          "default": {
            "enabled": true,
            "failureThreshold": 5,
            "cooldownSeconds": 30
          },
          "description": "%setting.nesCompletion.circuitBreaker.description%",
          "scope": "application",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "%setting.nesCompletion.circuitBreaker.enabled.description%"
            },
            "failureThreshold": {
              "type": "number",
              "default": 5,
              "minimum": 2,
              "maximum": 20,
              "description": "%setting.nesCompletion.circuitBreaker.failureThreshold.description%"
            },
            "cooldownSeconds": {
              "type": "number",
              "default": 30,
              "minimum": 10,
              "maximum": 300,
              "description": "%setting.nesCompletion.circuitBreaker.cooldownSeconds.description%"
            }
          }
        },
        "gcmp.nesCompletion.modelConfig": {
          "type": "object",
          "default": {
            "provider": "",
            "baseUrl": "",
            "model": ""
          },
          "description": "%setting.nesCompletion.modelConfig.description%",
          "scope": "application",
          "properties": {
            "provider": {
              "type": "string",
              "description": "%setting.modelConfig.provider.description%"
            },
            "baseUrl": {
              "type": "string",
              "description": "%setting.modelConfig.baseUrl.description%",
              "format": "uri"
            },
            "proxy": {
              "type": "string",
              "description": "%setting.modelConfig.proxy.description%",
              "anyOf": [
                {
                  "const": ""
                },
                {
                  "const": "noproxy"
                },
                {
                  "format": "uri"
                },
                {
                  "pattern": "^(?:(?:[^:@/\\s]+(?::[^@/\\s]*)?@)?(?:\\[[0-9A-Fa-f:.]+\\]|[^:/\\s?#]+)(?::\\d{1,5})?)$"
                }
              ]
            },
            "model": {
              "type": "string",
              "description": "%setting.nesCompletion.modelConfig.model.description%"
            },
            "maxTokens": {
              "type": "number",
              "description": "%setting.nesCompletion.modelConfig.maxTokens.description%",
              "default": 200,
              "minimum": 50,
              "maximum": 16000
            },
            "extraBody": {
              "type": "object",
              "description": "%setting.modelConfig.extraBody.description%",
              "additionalProperties": {
                "description": "%setting.modelConfig.extraBody.additionalProperties.description%"
              }
            }
          },
          "required": ["provider", "baseUrl", "model"]
        },
        "gcmp.commit.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%setting.commit.enabled.description%"
        },
        "gcmp.commit.language": {
          "type": "string",
          "enum": ["chinese", "english"],
          "enumDescriptions": [
            "%setting.commit.language.enumDescriptions.chinese%",
            "%setting.commit.language.enumDescriptions.english%"
          ],
          "default": "chinese",
          "description": "%setting.commit.language.description%",
          "scope": "window"
        },
        "gcmp.commit.format": {
          "type": "string",
          "enum": [
            "auto",
            "plain",
            "custom",
            "conventional",
            "angular",
            "karma",
            "semantic",
            "emoji",
            "emojiKarma",
            "google",
            "atom"
          ],
          "enumDescriptions": [
            "%setting.commit.format.enumDescriptions.auto%",
            "%setting.commit.format.enumDescriptions.plain%",
            "%setting.commit.format.enumDescriptions.custom%",
            "%setting.commit.format.enumDescriptions.conventional%",
            "%setting.commit.format.enumDescriptions.angular%",
            "%setting.commit.format.enumDescriptions.karma%",
            "%setting.commit.format.enumDescriptions.semantic%",
            "%setting.commit.format.enumDescriptions.emoji%",
